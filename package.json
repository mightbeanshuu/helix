{
  "name": "helix",
  "version": "0.1.0",
  "private": true,
  "description": "Helix — the codebase cartographer. Scan any repo, get an interactive map of its architecture, dependencies, hotspots, and AI-generated tour.",
  "homepage": "https://github.com/mightbeanshuu/helix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mightbeanshuu/helix.git"
  },
  "license": "MIT",
  "author": "mightbeanshuu",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "dev": "pnpm -r --parallel --stream dev",
    "dev:api": "pnpm --filter @helix/api dev",
    "dev:web": "pnpm --filter @helix/web dev",
    "dev:worker": "pnpm --filter @helix/worker dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @helix/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "clean": "pnpm -r exec rm -rf dist build .turbo .tsbuildinfo node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "globals": "^15.9.0",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.2.0",
    "vitest": "^2.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
