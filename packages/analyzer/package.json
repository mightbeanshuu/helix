{
  "name": "@helix/analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@helix/shared": "workspace:*",
    "@helix/parser": "workspace:*",
    "isomorphic-git": "^1.27.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.5"
  }
}
