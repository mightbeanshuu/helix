# ─────────────────────────────────────────────────────────────
# Helix — environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=development
LOG_LEVEL=info

# ── API ──
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173
API_BODY_LIMIT_MB=5
API_RATE_LIMIT_PER_MIN=120

# ── Web ──
VITE_API_URL=http://localhost:4000
VITE_SSE_URL=http://localhost:4000

# ── Storage (graph) ──
# Set STORAGE_DRIVER=neo4j to use Neo4j; otherwise the in-memory/sqlite fallback is used.
STORAGE_DRIVER=memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=helixhelix
NEO4J_DATABASE=neo4j

# ── Vector store ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=helix_code

# ── Job queue (Redis) ──
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=helix
QUEUE_CONCURRENCY=4

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=
HELIX_LLM_MODEL=claude-opus-4-7
HELIX_LLM_FAST_MODEL=claude-haiku-4-5-20251001
HELIX_LLM_BUDGET_USD=5.00

# ── Embeddings (Voyage AI) ──
VOYAGE_API_KEY=
HELIX_EMBED_MODEL=voyage-code-3

# ── GitHub (for private repo cloning) ──
GITHUB_TOKEN=

# ── Scan limits ──
HELIX_MAX_REPO_MB=512
HELIX_MAX_FILES=50000
HELIX_CLONE_DIR=./.helix/clones
HELIX_STORAGE_DIR=./.helix/storage
